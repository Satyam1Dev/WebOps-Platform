{
  "$schema": "https://json.schemastore.org/tsconfig",

  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "allowJs": false,
    "checkJs": false,

    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "isolatedModules": true,

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "removeComments": false,

    "incremental": true,

    "baseUrl": ".",

    "paths": {
      "@webops/ui/*": [
        "packages/ui/src/*"
      ],
      "@webops/types/*": [
        "packages/types/src/*"
      ],
      "@webops/utils/*": [
        "packages/utils/src/*"
      ],
      "@webops/config/*": [
        "packages/config/src/*"
      ],
      "@webops/database/*": [
        "packages/database/src/*"
      ],
      "@webops/validation/*": [
        "packages/validation/src/*"
      ],
      "@webops/shared/*": [
        "packages/shared/src/*"
      ]
    }
  },

  "exclude": [
    "node_modules",
    "dist",
    ".next",
    "coverage"
  ]
}